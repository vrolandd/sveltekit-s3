# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

# SvelteKit frontend (baked at build time)
PUBLIC_API_URL="https://your-lambda-api-gateway-url/prod"

# Lambda environment variables (set in AWS Lambda console, not here)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=
# S3_BUCKET_NAME=
# CLOUDFRONT_URL=
# ALLOWED_ORIGIN=    (your frontend URL, e.g. https://main.xxx.amplifyapp.com)
# DATABASE_URL=
